#!/usr/bin/env bash
# Resolve a Python interpreter that has the deps (click, google-api-python-client, ...).
# Order: plugin-local .venv (created by /gw-setup) -> python3/python on PATH.
# gw.py resolves its own plugin root from __file__, so no env vars are needed.
plugin_root="$(cd "$(dirname "$0")/.." && pwd)"
for py in "$plugin_root/.venv/bin/python3" "$plugin_root/.venv/bin/python"; do
  if [ -x "$py" ]; then exec "$py" "$plugin_root/cli/gw.py" "$@"; fi
done
exec "$(command -v python3 || command -v python)" "$plugin_root/cli/gw.py" "$@"
